{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(login|register|index)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(buyer|seller)/(.*)\\.php",
      "dest": "/api/$1/$2.php"
    },
    {
      "src": "/(buyer|seller)/(.*)",
      "dest": "/api/$1/$2.php"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ]
}

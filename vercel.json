{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(login|register|index|preview)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "/(buyer|seller|api)/(.*)\\.php",
      "dest": "/$1/$2.php"
    },
    {
      "src": "/",
      "dest": "/index.php"
    }
  ]
}

